{
  "name": "run-and-refuel",
  "version": "0.1.0",
  "private": true,
  "description": "Run & Refuel — Indian meal suggestions matched to your running activity",
  "scripts": {
    "start": "concurrently -n server,client -c blue,magenta \"npm:server\" \"npm:client\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "serve": "NODE_ENV=production node server/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
