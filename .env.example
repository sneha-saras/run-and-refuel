# Server port
PORT=3000

# --- Meal suggestion engine (OpenAI-compatible / Bifrost gateway) ---
# Leave OPENAI_API_KEY empty to run in MOCK mode (no API needed).
OPENAI_BASE_URL=
OPENAI_API_KEY=
MODEL_NAME=

# Optional: route the backend's gateway calls through a corporate proxy so it
# egresses from an allowlisted IP (e.g. behind Netskope/Zscaler).
# Only needed if the gateway is IP-restricted and this host isn't on the network.
GATEWAY_PROXY=

# --- Strava integration ---
# From https://www.strava.com/settings/api  (Authorization Callback Domain: your host, e.g. "localhost")
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Deploy-only: override the OAuth callback + post-login redirect for a hosted URL.
# Locally these default to http://localhost:3000/callback and http://localhost:5173.
# In production (NODE_ENV=production) the client redirect defaults to "/".
# STRAVA_REDIRECT_URI=https://your-host/callback
# CLIENT_URL=https://your-host
